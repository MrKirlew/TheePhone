<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.KirlewPHone" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/black</item>
        <item name="colorPrimaryVariant">@color/background_dark</item>
        <item name="colorOnPrimary">@color/text_primary</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/button_accent</item>
        <item name="colorSecondaryVariant">@color/button_dark</item>
        <item name="colorOnSecondary">@color/text_primary</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor" tools:targetApi="l">@color/background_dark</item>
        <!-- Window background -->
        <item name="android:windowBackground">@color/background_dark</item>
        <!-- Navigation bar color -->
        <item name="android:navigationBarColor">@color/nav_bar_background</item>
        <!-- Customize your theme here. -->
    </style>
</resources>