# Google Cloud Project Configuration
PROJECT_ID=your-project-id
REGION=us-central1

# OAuth Configuration
GOOGLE_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-oauth-client-secret
OAUTH_REDIRECT_URI=https://your-cloud-function-url/auth/callback

# Service Account
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json

# API Endpoints
CLOUD_FUNCTION_URL=https://your-region-your-project.cloudfunctions.net/multimodal-agent
CLOUD_RUN_URL=https://multimodal-agent-orchestrator-hash-uc.a.run.app

# Security
JWT_SECRET=your-random-jwt-secret-key
ALLOWED_ORIGINS=https://your-domain.com,https://localhost:3000

# Feature Flags
ENABLE_SPEECH_TO_TEXT=true
ENABLE_VISION_ANALYSIS=true
ENABLE_GMAIL_ACCESS=true
ENABLE_CALENDAR_ACCESS=true